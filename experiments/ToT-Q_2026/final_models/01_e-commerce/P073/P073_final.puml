@startuml
class Customer {
    - id : String
}
class Order {
    - id : String
}
class Product {
    - name : String
    - description : String
}
class OrderItem {
    - quantityRequested : Integer
    - agreedPrice : Decimal
}
class Review {
    - reviewDate : Date
    - ratingScore : Integer
}
class Promotion {
}
class ProductPromotion {
    - discountRate : Decimal
    - startDate : Date
    - endDate : Date
}
Customer "1" -- "0..*"  Order : Places
OrderItem "1" -- "0..*"  Product : ForProduct
Customer "1" -- "0..*"  Review : Writes
Order "1" *-- "1..*"  OrderItem
Promotion "1" *-- "0..*"  ProductPromotion
Product "0..1" -- "0..*"  ProductPromotion : LinkedOffer
Product "0..1" -- "1..*"  Review : Receives
@enduml