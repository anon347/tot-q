@startuml
class Customer {
    - customerId : String
}
class Order {
    - orderId : String
}
class Product {
    - name : String
    - description : String
}
class OrderItem {
    - quantity : Integer
    - agreedPrice : Decimal
}
class Promotion {
    - promotionId : String
}
Customer "1" -- "0..*"  Order : Places
Order "1" *-- "1..*"  OrderItem : Order_Contains_OrderItem
OrderItem "0..1" *-- "1"  Product
Customer "*" -- "*"  Product : associates
Product "*" -- "*"  Promotion
class Review {
    - dateWritten : Date
    - ratingScore : Integer
}
(Customer, Product) .. Review
class ProductPromotion {
    - discountRate : Decimal
    - startDate : Date
    - endDate : Date
}
(Product, Promotion) .. ProductPromotion
@enduml