@startuml
class Customer {
    - customerId : String
}
class Order {
    - orderId : String
}
class Product {
    - name : String
    - description : String
}
class Review {
    - dateWritten : Date
    - ratingScore : Integer
}
class PromotionalCampaign {
}
Customer "1" -- "0..*"  Order : Places
Customer "1" -- "0..*"  Review : Writes
Product "1" -- "0..*"  Review : ReceivesReviews
Order "1" *-- "1..*"  OrderItem
OrderItem "0..*" -- "1..*"  Product : ForProduct
Product "*" -- "*"  PromotionalCampaign : associates
class OrderItem {
    - quantityRequested : Integer
    - agreedPrice : Decimal
}
(Order, Product) .. OrderItem
class ProductPromotion {
    - discountRate : Decimal
    - startDate : Date
    - endDate : Date
}
(Product, PromotionalCampaign) .. ProductPromotion
@enduml