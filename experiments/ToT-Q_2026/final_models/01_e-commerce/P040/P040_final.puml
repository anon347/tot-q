@startuml
class Customer {
    - customerId : String
}
class Order {
    - orderId : String
}
class Product {
    - name : String
    - description : String
}
class OrderItem {
    - quantity : Integer
    - agreedPrice : Decimal
}
class Review {
    - reviewDate : Date
    - ratingScore : Integer
}
class Promotion {
    - promotionId : String
}
Customer "1" -- "0..*"  Order : Places
Customer "1" -- "0..*"  Review : Writes
Product "1" -- "0..*"  Review : Receives
Order "1" *-- "1..*"  OrderItem : Order_Contains_OrderItem
OrderItem "1..*" -- "1"  Product : RefersTo
Product "*" -- "*"  Promotion : associates
class ProductPromotion {
    - discountRate : Decimal
    - startDate : Date
    - endDate : Date
}
(Product, Promotion) .. ProductPromotion
@enduml