@startuml
class Customer {
    - customerId : String
}
class Order {
    - orderId : String
}
class Product {
    - name : String
    - description : String
}
class PromotionalCampaign {
}
Customer "1" -- "0..*"  Order : Places
Product "*" -- "*"  Order : associates
Customer "*" -- "*"  Product
Product "*" -- "*"  PromotionalCampaign
class OrderItem {
    - quantityRequested : Integer
    - agreedPrice : Decimal
}
(Product, Order) .. OrderItem
class Review {
    - dateWritten : Date
    - ratingScore : Integer
}
(Customer, Product) .. Review
class ProductPromotion {
    - discountRate : Decimal
    - startDate : Date
    - endDate : Date
}
(Product, PromotionalCampaign) .. ProductPromotion
@enduml