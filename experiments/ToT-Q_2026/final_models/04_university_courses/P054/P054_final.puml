@startuml
class Student {
    - studentCode : String
}
class Course {
}
class TeachingAssistant {
    - firstName : String
    - lastName : String
}
class LabSection {
    - location : String
    - timeSlot : string
}
class Assignment {
}
class Role {
    - description : string
}
Course "1" *-- "1..*"  LabSection
Course "1" *-- "0..*"  Assignment
Assignment "1" -- "1"  Assignment : has
Assignment "0..1" -- "0..1"  Role
TeachingAssistant "0..1" -- "0..1"  Assignment : AssignedRoles
Student "*" -- "*"  Course : associates
class Enrollment {
    - date : Date
}
(Student, Course) .. Enrollment
@enduml