@startuml
class Student {
    - studentCode : String
}
class TeachingAssistant {
    - firstName : String
    - lastName : String
}
class LabSection {
    - location : String
    - startTime : Time
    - endTime : Time
}
class Course {
}
class CourseDetails {
    - name : string
}
class CourseType {
    - name : string
    - description : string
}
Course "1" *-- "1..*"  LabSection
Course "1" *-- "1"  CourseDetails
CourseDetails "1" -- "1..*"  CourseType : has
Student "*" -- "*"  Course : associates
TeachingAssistant "*" -- "*"  Course
class Enrollment {
    - enrollmentDate : Date
}
(Student, Course) .. Enrollment
class Assignment {
    - details : String
    - responsibilities : String
}
(TeachingAssistant, Course) .. Assignment
@enduml