@startuml
class Student {
    - studentCode : String
}
class TeachingAssistant {
    - firstName : String
    - lastName : String
}
class Course {
    - University : string
}
class LabSection {
    - location : String
    - TimeSlot : string
}
Course "1" *-- "1"  LabSection
Student "*" -- "*"  Course : associates
TeachingAssistant "*" -- "*"  Course
class Enrollment {
    - date : Date
}
(Student, Course) .. Enrollment
class Assignment {
    - details : String
    - responsibilities : String
}
(TeachingAssistant, Course) .. Assignment
@enduml