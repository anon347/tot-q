@startuml
class Student {
    - studentCode : String
}
class Course {
    - courseName : String
}
class Enrollment {
    - enrollmentDate : Date
}
class TeachingAssistant {
    - firstName : String
    - lastName : String
}
class LabSection {
    - location : String
    - startTime : Time
    - endTime : Time
}
Student "1" -- "0..*"  Enrollment : EnrollsIn
Course "1" *-- "0..*"  Enrollment
Course "0..1" -- "0..*"  LabSection : ContainsLabSection
LabSection "0..*" -- "0..1"  TeachingAssistant : SupportedBy
Course "*" -- "*"  TeachingAssistant : associates
class Assignment {
    - details : String
    - responsibilities : String
}
(Course, TeachingAssistant) .. Assignment
@enduml