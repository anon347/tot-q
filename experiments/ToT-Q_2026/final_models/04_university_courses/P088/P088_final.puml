@startuml
class Student {
    - studentCode : String
}
class Course {
}
class TeachingAssistant {
    - firstName : String
    - lastName : String
}
class LabSection {
    - location : String
}
class TimeSlot {
    - startTime : Time
    - endTime : Time
}
class Assignment {
    - responsibilities : String
    - details : String
}
class TARole {
    - name : string
    - description : string
}
Course "1" *-- "1"  LabSection
Course "1..*" -- "0..1"  Assignment : TaAssignments
Assignment "0..1" -- "1"  TARole : has
TeachingAssistant "1..*" -- "0..1"  Assignment : Assignments
LabSection "0..1" -- "1"  TimeSlot : TimeSlot
Course "*" -- "*"  Student : associates
class Enrollment {
    - date : Date
}
(Course, Student) .. Enrollment
@enduml