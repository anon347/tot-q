@startuml
class Student {
    - studentCode : String
}
class Course {
}
class TeachingAssistant {
    - firstName : String
    - lastName : String
}
class LabSection {
    - location : String
    - timeSlot : string
}
Course "1" *-- "1..*"  LabSection
Course "*" -- "*"  Student : associates
Course "*" -- "*"  TeachingAssistant
class Enrollment {
    - date : Date
}
(Course, Student) .. Enrollment
class Assignment {
    - details : String
    - responsibilities : String
}
(Course, TeachingAssistant) .. Assignment
@enduml