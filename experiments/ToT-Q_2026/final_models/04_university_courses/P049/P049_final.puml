@startuml
class Student {
    - studentCode : String
}
class Course {
    - courseName : String
}
class TeachingAssistant {
    - firstName : String
    - lastName : String
}
class LabSection {
    - location : String
    - startTime : Time
    - endTime : Time
}
Course "1" *-- "1..*"  LabSection
Student "*" -- "*"  Course : associates
Course "*" -- "*"  TeachingAssistant
class Enrollment {
    - enrollmentDate : Date
}
(Student, Course) .. Enrollment
class Assignment {
    - details : String
    - responsibilities : String
}
(Course, TeachingAssistant) .. Assignment
@enduml