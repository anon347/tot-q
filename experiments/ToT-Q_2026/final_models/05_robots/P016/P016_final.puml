@startuml
abstract class Robot {
    - identifier : String
}
class CleaningRobot {
}
class TransportRobot {
}
class Task {
    - code : String
}
enum LocationCategory {
    corridor
    room
}
Robot <|-- CleaningRobot
Robot <|-- TransportRobot
Task "*" -- "*"  Robot : associates
class TaskExecution {
    - referenceCode : String
    - startTime : DateTime
    - locationCategory : LocationCategory
}
(Task, Robot) .. TaskExecution
@enduml