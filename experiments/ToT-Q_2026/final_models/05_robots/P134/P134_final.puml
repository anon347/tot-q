@startuml
abstract class Robot {
    - identifier : String
}
class CleaningRobot {
}
class TransportRobot {
}
class Task {
    - code : String
}
class TaskExecution {
    - referenceCode : String
    - startTime : DateTime
    - locationCategory : LocationCategory
}
class Facility {
    - id : String
}
enum LocationCategory {
    Corridor
    Room
}
Robot <|-- CleaningRobot
Robot <|-- TransportRobot
Facility "0..1" -- "0..1"  Robot : ContainsRobots
Facility "1" *-- "1"  Task
Robot "1..*" -- "0..*"  Task : AssignedToPerform
Facility "1" -- "0..1"  TaskExecution : RecordsExecutions
Robot "1..*" -- "0..1"  TaskExecution : Performs
Task "1" -- "0..1"  TaskExecution : HasExecutions
@enduml