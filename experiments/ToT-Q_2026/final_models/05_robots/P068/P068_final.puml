@startuml
class Task {
    - code : String
}
class TaskExecution {
    - referenceCode : String
    - startTime : DateTime
    - locationCategory : LocationCategory
}
class Facility {
    - id : String
}
class Robot {
    - identifier : String
    - RobotType : RobotType
}
enum LocationCategory {
    Corridor
    Room
}
enum RobotType {
    CLEANING
    TRANSPORT
}
Robot "0..*" -- "0..*"  Task : AssignedToPerform
Facility "0..1" -- "0..1"  Robot : ContainsRobots
Facility "1" -- "0..1"  Task : DefinesTasks
Facility "1" *-- "1"  TaskExecution
Robot "1..*" -- "0..1"  TaskExecution : Performs
Task "1" -- "0..1"  TaskExecution : HasExecutions
@enduml