@startuml
abstract class Robot {
    - robotId : String
}
class CleaningRobot {
}
class TransportRobot {
}
class Task {
    - taskCode : String
}
class TaskExecution {
    - referenceCode : String
    - startTime : DateTime
    - locationCategory : LocationCategory
}
enum LocationCategory {
    Corridor
    Room
}
Robot "0..*" -- "1"  TaskExecution : Performs
Robot <|-- CleaningRobot
Robot <|-- TransportRobot
Robot "1..*" -- "0..*"  Task : AssignedTo
Task "1" *-- "1"  TaskExecution
@enduml