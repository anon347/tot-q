@startuml
class User {
    - password : String
}
abstract class Resource {
    - name : String
}
class File {
}
class Folder {
}
class Person {
    - name : String
    - identifier : String
    - AncestorRelation : string
}
Person "0..*" -- "0..1"  Person : ParentOf
Folder "0..1" *-- "0..1"  Folder
Person <|-- User
Resource <|-- File
Resource <|-- Folder
Folder "1" *-- "1"  File
User "*" -- "*"  Resource : associates
class ResourceAccess {
    - canView : Boolean
    - canEdit : Boolean
}
(User, Resource) .. ResourceAccess
@enduml