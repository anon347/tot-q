@startuml
class Person {
    - name : String
    - identifier : String
}
abstract class Resource {
    - name : String
}
class File {
}
class Folder {
}
class User {
    - password : String
}
class AccessPermission {
    - canEdit : Boolean
}
class AncestorDegree {
    - degree : Integer
}
Person "0..1" -- "0..*"  Person : Parent
Person "0..*" -- "0..1"  Person : Children
Folder "0..1" *-- "1"  Resource : Folder_Contains_Resource
Folder "0..1" *-- "0..*"  Folder
Resource <|-- File
Resource <|-- Folder
Person <|-- User
Person "0..*" -- "0..1"  AncestorDegree : Ancestors
User "0..*" -- "0..*"  AccessPermission : Permissions
Resource "0..*" -- "0..*"  AccessPermission : AccessedBy
@enduml