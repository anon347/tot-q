@startuml
class Theater {
    - location : String
    - name : String
}
abstract class Play {
    - name : String
    - timeOfDay : TimeOfDay
}
class Musical {
}
class Opera {
}
class Author {
    - name : String
}
class Participant {
    - name : String
}
class Session {
    - scheduledDate : Date
    - startTime : Time
    - endTime : Time
}
enum TimeOfDay {
    Day
    Night
}
Play "1..*" -- "1..*"  Author : WrittenBy
Play "1..*" -- "1..*"  Participant : Involves
Session "1..*" -- "0..*"  Participant : ActsIn
Theater "1" *-- "1..*"  Session
Play "1" *-- "1..*"  Session
Play <|-- Musical
Play <|-- Opera
(Theater , Participant) .. Session
@enduml