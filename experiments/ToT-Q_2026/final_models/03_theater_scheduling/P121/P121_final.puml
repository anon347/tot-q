@startuml
class Theater {
    - location : String
    - name : String
}
abstract class Play {
    - name : String
    - timeOfDay : TimeOfDay
}
class Musical {
}
class Opera {
}
class Author {
    - name : String
}
class Participant {
    - name : String
}
enum TimeOfDay {
    Day
    Night
}
Play "1..*" -- "1..*"  Author : WrittenBy
Play "1..*" -- "1..*"  Participant : Involves
Play <|-- Musical
Play <|-- Opera
Theater "*" -- "*"  Play : associates
class Session {
    - scheduledDate : Date
    - startTime : Time
    - endTime : Time
}
(Theater, Play) .. Session
@enduml