@startuml
class Theater {
    - location : String
}
abstract class Play {
    - name : String
    - timeOfDay : TimeOfDay
}
class Musical {
}
class Opera {
}
class Author {
}
class Participant {
}
abstract class Person {
    - name : String
}
enum TimeOfDay {
    Day
    Night
}
Play <|-- Musical
Play <|-- Opera
Person <|-- Author
Person <|-- Participant
Play "1..*" -- "1..*"  Author : WrittenBy
Play "0..1" -- "1..*"  Participant : InvolvesParticipant
Play "0..*" -- "1..*"  Theater : PerformedAt
class Session {
    - scheduledDate : Date
    - startTime : Time
    - endTime : Time
}
(Play, Theater) .. Session
@enduml