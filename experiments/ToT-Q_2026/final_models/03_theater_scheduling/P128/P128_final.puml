@startuml
class Theater {
    - location : String
    - name : String
}
abstract class Play {
    - name : String
    - timeOfDay : TimeOfDay
}
class Musical {
}
class Opera {
}
class Author {
}
class Participant {
}
abstract class Person {
    - name : String
}
enum TimeOfDay {
    Day
    Night
}
Play "1..*" -- "1..*"  Author : WrittenBy
Play "1..*" -- "1..*"  Participant : Involves
Play <|-- Musical
Play <|-- Opera
Person <|-- Participant
Person <|-- Author
Play "*" -- "*"  Theater : associates
class Session {
    - scheduledDate : Date
    - startTime : Time
    - endTime : Time
}
(Play, Theater) .. Session
@enduml