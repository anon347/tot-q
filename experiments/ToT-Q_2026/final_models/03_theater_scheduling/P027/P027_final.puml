@startuml
abstract class Play {
    - name : String
    - timeOfDay : TimeOfDay
}
class Musical {
}
class Opera {
}
class Author {
    - name : String
}
class Participant {
    - name : String
}
class Theater {
    - location : String
}
enum TimeOfDay {
    Day
    Night
}
Play "1..*" -- "1..*"  Participant : Involves
Play <|-- Musical
Play <|-- Opera
Play "0..*" -- "1..*"  Author : IsWrittenBy
Author "0..1" -- "1"  Participant : IsSamePersonAs
Theater "0..1" -- "0..*"  Author : has
Theater "*" -- "*"  Play : associates
class Session {
    - scheduledDate : Date
    - startTime : Time
    - endTime : Time
}
(Theater, Play) .. Session
@enduml